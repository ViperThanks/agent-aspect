# agent-aspect-relay environment variables
#
# Copy this file to .env and edit before running docker compose.
# All variables are optional -- the relay generates defaults on first start.

# Address and port the relay listens on (inside the container).
# Default: 0.0.0.0:8080
# RELAY_LISTEN_ADDR=0.0.0.0:8080

# Host port to map to the container port.
# Default: 8080
# RELAY_LISTEN_PORT=8080

# HMAC signing key for JWT tokens.
# Auto-generated on first start if not set.
# Set this to a fixed value if you want tokens to survive container recreation.
# RELAY_SECRET=

# One-time registration token for /api/register.
# Auto-generated on first start if not set.
# Print to stderr on first generation -- copy it before it scrolls away.
# RELAY_SETUP_TOKEN=
